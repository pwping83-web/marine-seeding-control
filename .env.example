# 브라우저(Vite) — createClient용. URL은 /rest/v1/ 없이 프로젝트 루트만
# 공식 프로덕션 URL (카카오 비즈·문서에 기재할 주소)
# VITE_SITE_URL=https://marine-seeding-control-git-main-pwping83-webs-projects.vercel.app

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
VITE_SUPABASE_PUBLISHABLE_KEY=your_sb_publishable_key

# Node 스크립트·CI 등 서버 측만. 절대 VITE_ 로 붙이지 말 것
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# Settings → API 의 Secret key (Default), sb_secret_ 형식 — 서버 전용
SUPABASE_SECRET_KEY_DEFAULT=your_sb_secret_key

# dashboard/account/tokens — Management API·CLI용. VITE_ 금지
SUPABASE_ACCESS_TOKEN=

# sql:run 용. Direct(db.*)가 ENOTFOUND 이면 대시보드 Session pooler URI 를 아래에만 넣어도 됨
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
DATABASE_URL_POOLER=

# Kakao (앱에 카카오 로그인 붙일 때). REST 키는 VITE_ 금지
VITE_KAKAO_JAVASCRIPT_KEY=
KAKAO_REST_API_KEY=

# EmailJS — 로그인 성공(입장) 시 알림 메일(공개 키·서비스·템플릿 ID). 템플릿 본문에 {{service_name}} {{access_location}} {{access_time}}
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=

# 공동·금융 인증서(구 공인인증서 계열) — 외부 OIDC/GPKI 게이트웨이 시작 URL. 미설정 시 UI 안내만 표시
VITE_GOVT_CERT_LOGIN_GATEWAY_URL=

# Supabase Edge `telemetry-ingest` — 기기에서 살포 기록 업로드 시 헤더 X-Device-Ingest-Key 와 일치시킬 값(서버 secret)
# DEVICE_INGEST_SECRET=

# 대시보드: DB에서 불러올 선박 ID(vessel_track_points.vessel_id). 비우면 기본 함명
# VITE_VESSEL_LTE_ID=제3해양살포함
# VITE_VESSEL_LTE_POLL_MS=12000

# 아두이노 등으로 seed_drop_records 가 갱신될 때 지도 마커 주기(ms). 4000~120000
# VITE_SEED_DROP_POLL_MS=12000

# 나라장터 입찰공고 알림 — scripts/g2b-bid-watch.mjs (공공데이터포털 OpenAPI, 크롤링 아님)
# data.go.kr 에서 '나라장터 입찰공고정보' 등 활용신청 후 일반 인증키
# DATA_GO_KR_SERVICE_KEY=
# Discord/Slack Incoming Webhook URL (둘 중 하나는 ntfy 와 병행 가능)
# G2B_NOTIFY_WEBHOOK_URL=
# 스마트폰 알림: ntfy 앱 설치 후 임의 토픽명 — https://ntfy.sh
# G2B_NTFY_TOPIC=
# 쉼표 구분 공고명 부분일치(비우면 키워드 무시). 종자·살포만 두지 말고 해도·지도·공간정보·해저시설 등 병행. 예: 해양,해도,GIS,공간정보,케이블,관제,IoT
# G2B_KEYWORDS=
# 조회 시작 = 오늘부터 며칠 전까지 (1~14, 기본 2)
# G2B_INQRY_DAYS=2
# 첫 실행 시 알림 생략하고 ID만 저장(1) / 첫 실행부터 알림(0)
# G2B_FIRST_RUN_SEED_ONLY=1
# 입찰 유형(쉼표): servc=용역, thng=물품, cnstwk=공사. 예: 용역만 → servc
# G2B_BID_TYPES=servc,thng,cnstwk

# 나라장터 외 공고 자동 수집·필터 — scripts/gov-announce-watch.mjs (HTML 파싱, 사이트 구조 변경 시 수정 필요)
# 키워드·소스 on/off 는 scripts/gov-announce-watch.config.json
# GOV_ANNOUNCE_AS_OF=2026-05-10
# GOV_ANNOUNCE_STATE_FILE=scripts/.gov-announce-watch-state.json
# GOV_ANNOUNCE_FIRST_RUN_SEED_ONLY=1
# GOV_ANNOUNCE_NOTIFY_WEBHOOK_URL=
# GOV_ANNOUNCE_NTFY_TOPIC=

# Windows: 3일마다 오후 3시경 알림 — scripts/Register-G2bWatchScheduledTask.ps1 (관리자) 실행 후
# 수동으로 간격만 시험: pnpm run g2b:watch:scheduled  (마커 파일 없으면 즉시 1회 실행)

# 지원사업 공고 Open API — scripts/bizinfo24-pblanc.mjs
# · 기업마당: crtfcKey (기본 URL bizinfoApi.do)
# · 중소벤처24 공고연계(공고정보 연계 API 가이드): URL 이 extPblancInfo 이면 쿼리 파라미터 이름은 token (값은 BIZINFO24_CRTFC_KEY 와 동일하게 넣음)
# 안내: https://www.smes.go.kr/main/dbCnrs  ·  https://www.bizinfo.go.kr/
# BIZINFO24_CRTFC_KEY=
# BIZINFO24_API_URL=https://www.bizinfo.go.kr/uss/rss/bizinfoApi.do
# BIZINFO24_API_URL=https://www.smes.go.kr/fnct/apiReqst/extPblancInfo
# 중소벤처24 기간(yyyyMMdd, 비우면 config 의 smesDateRangeDays 로 자동)
# BIZINFO24_SMES_STR_DT=
# BIZINFO24_SMES_END_DT=
# 키워드·페이지·기간일수는 scripts/bizinfo24-pblanc.config.json (또는 BIZINFO24_CONFIG=경로)

# 지원사업 통합 허브 — scripts/grant-watch/run.mjs (npm run grant:watch)
# 중소벤처24 공고정보 연계 API 가이드의 token (crtfcKey·serviceKey 아님). 없으면 SMES 소스만 생략.
# SMES_EXT_PBLANC_KEY=
# GRANT_WATCH_SKIP_NTIS=1
# GRANT_WATCH_SKIP_SMES=1

# ─── AI 기상 분석 (WeatherAIPanel) ─────────────────────────────────────────────
# 기상청 단기예보 Open API 인증키 (공공데이터포털 → 기상청 단기예보 활용신청 후 일반 인증키 URL인코딩 값)
# 발급: https://www.data.go.kr/data/15084084/openapi.do
# 미설정 시 WeatherAIPanel이 목업(시연) 데이터로 동작합니다.
# VITE_KMA_SERVICE_KEY=YOUR_KMA_SERVICE_KEY
# 남해안 권역 기상청 격자 좌표 (기본값: NX=58 NY=74)
# VITE_KMA_NX=58
# VITE_KMA_NY=74

# ─── Groq AI (LLM 기상 분석·자연어 리포트) ──────────────────────────────────
# 발급: https://console.groq.com → API Keys
# 사용 모델 예시: llama-3.3-70b-versatile, llama3-8b-8192 (무료 플랜 가능)
# VITE_GROQ_API_KEY=gsk_...
